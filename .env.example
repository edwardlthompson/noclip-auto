# Environment variables (copy to .env and fill in)
# Never commit .env — it is gitignored.

# Template update checker upstream (optional override)
# TEMPLATE_UPSTREAM=edwardlthompson/agent-project-bootstrap

# Lightroom install path override (optional — scripts auto-detect)
# LR_INSTALL_DIR=C:\Program Files\Adobe\Adobe Lightroom Classic

# Project-specific (add below)
# LOG_LEVEL=info
